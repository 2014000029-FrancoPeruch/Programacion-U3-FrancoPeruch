Algoritmo Clase_ejemplo
	Definir colores como caracter
	Definir n como entero
	
	Dimensionar colores[8]
	colores[1] = "Café"
	colores[2] = "Morado"
	colores[3] = "Corinto"
	colores[4] = "Rojo"
	colores[5] = "Verde Claro"
	colores[6] = "Verde Oscuro"
	colores[7] = "Violeta"
	colores[8] = "Negro"
	
	Para n = 1 Hasta 8 Con Paso 1 Hacer
		Escribir Sin Saltar colores[n], " | "
	Fin Para
FinAlgoritmo
